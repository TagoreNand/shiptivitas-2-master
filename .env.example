# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# --- Postgres --------------------------------------------------------------
DATABASE_URL=postgres://shiptivity:shiptivity@localhost:5432/shiptivity
DB_POOL_MAX=10

# --- Redis / events --------------------------------------------------------
REDIS_URL=redis://localhost:6379
EVENTS_CHANNEL=board.events
OUTBOX_POLL_MS=1000
OUTBOX_BATCH_SIZE=100

# --- Concurrency -----------------------------------------------------------
TX_MAX_RETRIES=5

# --- Security --------------------------------------------------------------
# Comma-separated allow-list, or * for any origin (dev only).
CORS_ORIGINS=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# --- Auth (JWT) ------------------------------------------------------------
# false (dev): anonymous allowed, scopes not enforced.
# true  (prod): a valid Bearer token with `board:write` is required for moves.
AUTH_REQUIRED=false
JWT_SECRET=dev-secret-change-me
JWT_ISSUER=shiptivity
JWT_AUDIENCE=shiptivity-api
# Set to verify RS256/ES256 OIDC tokens via JWKS instead of the HS256 secret:
JWKS_URI=

# --- OpenTelemetry tracing -------------------------------------------------
TRACING_ENABLED=false
OTEL_SERVICE_NAME=shiptivity-api
# OTLP/HTTP endpoint of a Collector or Jaeger (compose exposes Jaeger here):
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
